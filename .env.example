# 基础运行配置
APP_ENV=development
SECRET_KEY=change-me-before-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
DEFAULT_EXCHANGE=binance
ENABLE_LIVE_TRADING=false

# 数据与缓存连接
POSTGRES_DB=quantitative_trading
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_password
DATABASE_URL=postgresql+psycopg://quant:quant_dev_password@postgres:5432/quantitative_trading
REDIS_URL=redis://redis:6379/0

# 前端公开配置
NEXT_PUBLIC_APP_NAME=量化交易控制台
NEXT_PUBLIC_API_BASE_URL=/api/v1
